<% layout("layouts/boilerplate") %>

<div class="row mt-3">
    <h1 class="col-6 offset-3">Login</h1>
<div class="col-6 offset-3">
<form method="post" action="/login" novalidate class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="username" class="form-label">Username</label>
        <input 
        type="username"
         name="username"
         id="username"
          class="form-control" 
           required >
    
        </div>

        <div class="mb-3">
            <label for="password"> Password</label>
            <input type="password"
             name="password"
             id="password"
             class="form-control"
             required
            />
        </div>
        <button class="btn btn-success">login</button>
        </div>
        </div>