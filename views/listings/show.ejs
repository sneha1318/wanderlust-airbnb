 <% layout("layouts/boilerplate") %>
 <!-- <script>
  const mapToken="<%= process.env.MAP_TOKEN%>";
 </script> -->

    <div class="row mt-3">
        <div class="col-8 offset-3">
    <h3><%=listing.title%></h3>
    </div>
    <div class="col-6 offset-3">
<div class="card show-card listing-card" style="width: 30rem" >
  <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listingimage">
  <div class="card-body">
   
    <p class="card-text">
<i>Owned By : <%= listing.owner ? listing.owner.username : "Unknown" %></i>
</p>
      
    
       <p class="card-text"></pclass> <%=listing.description%> </p>
        <p class="card-text"></p><% if (listing.price != null) { %>
  &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
<% } else { %>
  <span class="text-muted">Price not available</span>
<% } %> 
    </p>
       <p class="card-text"></p> <%=listing.location%> </p>
       <p class="card-text"></p><%=listing.country%></p>


  </div>
</div>



</div>
</div>

<!-- ✅ ADD BOOKING FORM HERE (EXACT POSITION) -->
<div class="col-6 offset-3 mt-3">
  <% if(curruser){ %>
    <div class="card p-3">
      <h4>Book this stay</h4>

      <form action="/bookings/<%= listing._id %>" method="POST">
       
        <input type="text" id="fromDate" name="from" 
  class="form-control mb-3" 
  placeholder="Select Check-in" required>

<input type="text" id="toDate" name="to" 
  class="form-control mb-3" 
  placeholder="Select Check-out" required>

        <button class="btn btn-dark w-100">Book Now</button>
      </form>


      
    </div>
  <% } %>
</div>




<% if(curruser && listing.owner._id.equals(curruser._id)) { %>

<div class="btns ">
    <a  class=" btn btn-dark col-1 offset-3 edit-btn" href="/listing/<%=listing._id %>/edit">Edit </a>
   
    <form method="post"   action="/listing/<%=listing.id  %>?_method=DELETE">
        <button class="btn btn-dark offset-5">Delete</button>
    </form>
   
    </div>
    <% } %>
    


    <div class="col-8 offset-3">
     <hr>
      <% if(curruser){ %>
      <h4>Leave a review</h4>
           <form action="/listing/<%=listing.id%>/review" method="post" novalidate class="needs-validation">
            <!-- <div class="mb-3 mt-3">
            <label for="rating" class="form-label">Rating</label>
            <input type="range" min="1" max="5" name="review[rating]" id="rating" class="form-range" >

            </div> -->
             <div class="mb-3 mt-3">
              <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot">
  
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
</div>
            <div class="mb-3 mt-3">
            <label for="comment" class="form-label">Comment</label >
            <textarea name="review[comment]" id="comment" cols="100"  rows="5" class="form-control" required></textarea>
            <div class="invalid-feedback">please add some comments</div>
            </div>
            <button class="btn btn-dark" >submit</button>
            <br><br>
           </form>
           <% } %>
           
           
          <% if(listing.reviews.length >0 ) {%>
           <div class="row">
             <p><b>All Reviews</b></p>
          <% for(review of listing.reviews){ %>
            <div class="card col-5 mb-3 ms-3">
              <div class="card-body">
                <h5 class="card-title">@<%=review.author.username%></h5>
                <p class="card-text"><%=review.comment%></p>
              
                <p class="starability-result card-text" data-rating="<%=review.rating%>">
    Rated: 3 stars
  </p>
                <form class="mb-3" method="post" action="/listing/<%= listing._id  %>/review/<%=review._id  %>?_method=DELETE">
                  <button class="btn btn-sm btn-dark">Delete</button>
                </form>
              </div>

            </div>
            <% } %>
            </div>
            <% } %>
           
    </div>
     <div class="col-8 offset-3 mb-3">
              <h3>Where you'll be </h3>
              <div id="map"></div>
            
          </div>
    </div>
    <!-- <br><br> -->
     <script>
    const listing = <%- JSON.stringify(listing) %>;
</script>

 

<!-- ✅ ADD YOUR CALENDAR SCRIPT HERE -->
<script>
  document.addEventListener("DOMContentLoaded", function () {

    const toPicker = flatpickr("#toDate", {
      minDate: "today",
      dateFormat: "Y-m-d"
    });

    flatpickr("#fromDate", {
      minDate: "today",
      dateFormat: "Y-m-d",
      onChange: function(selectedDates, dateStr) {
        toPicker.set("minDate", dateStr);
      }
    });

  });
</script>
  
    <script src="/js/map.js"></script>
    
    





