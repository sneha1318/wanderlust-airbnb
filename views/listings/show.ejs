<% layout("layouts/boilerplate") %>

<div class="container">

  <div class="row mt-3">
    <div class="col-12 col-md-8 offset-md-2">
      <h3><%= listing.title %></h3>
    </div>

    <div class="col-12 col-md-6 offset-md-3">
      <div class="card show-card listing-card w-100">
        <img
          src="<%= listing.image.url %>"
          class="card-img-top show-img"
          alt="listing image"
        >

        <div class="card-body">

          <p class="card-text">
            <i>
              Owned By :
              <%= listing.owner?.username || "Unknown" %>
            </i>
          </p>

          <p class="card-text">
            <%= listing.description %>
          </p>

          <p class="card-text">
            <% if (listing.price != null) { %>
              ₹<%= listing.price.toLocaleString("en-IN") %>/night
            <% } else { %>
              <span class="text-muted">Price not available</span>
            <% } %>
          </p>

          <p class="card-text">
            <%= listing.location %>
          </p>

          <p class="card-text">
            <%= listing.country %>
          </p>

        </div>
      </div>
    </div>
  </div>

  <!-- Booking Section -->

  <% if (locals.curruser) { %>

    <div class="row">
      <div class="col-12 col-md-6 offset-md-3 mt-3">

        <div class="card p-3">
          <h4>Book this stay</h4>

          <form action="/bookings/<%= listing._id %>" method="POST">

            <input
              type="text"
              id="fromDate"
              name="from"
              class="form-control mb-3"
              placeholder="Select Check-in"
              required
            >

            <input
              type="text"
              id="toDate"
              name="to"
              class="form-control mb-3"
              placeholder="Select Check-out"
              required
            >

            <button class="btn btn-dark w-100">
              Book Now
            </button>

          </form>
        </div>

      </div>
    </div>

  <% } %>

  <!-- Owner Controls -->

  <% if (
      locals.curruser &&
      listing.owner &&
      listing.owner._id.equals(locals.curruser._id)
  ) { %>

    <div class="d-flex flex-wrap gap-2 justify-content-center my-4">

      <a
        class="btn btn-dark"
        href="/listing/<%= listing._id %>/edit"
      >
        Edit
      </a>

      <form
        method="POST"
        action="/listing/<%= listing.id %>?_method=DELETE"
      >
        <button class="btn btn-danger">
          Delete
        </button>
      </form>

    </div>

  <% } %>

  <!-- Reviews -->

  <div class="row">
    <div class="col-12 col-md-8 offset-md-2">

      <hr>

      <% if (locals.curruser) { %>

        <h4>Leave a Review</h4>

        <form
          action="/listing/<%= listing.id %>/review"
          method="POST"
          novalidate
          class="needs-validation"
        >

          <div class="mb-3 mt-3">

            <label for="rating" class="form-label">
              Rating
            </label>

            <fieldset class="starability-slot">

              <input
                type="radio"
                id="no-rate"
                class="input-no-rate"
                name="review[rating]"
                value="1"
                checked
                aria-label="No rating."
              />

              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1">1 star</label>

              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2">2 stars</label>

              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3">3 stars</label>

              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4">4 stars</label>

              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5">5 stars</label>

            </fieldset>

          </div>

          <div class="mb-3 mt-3">

            <label for="comment" class="form-label">
              Comment
            </label>

            <textarea
              name="review[comment]"
              id="comment"
              rows="5"
              class="form-control"
              required
            ></textarea>

            <div class="invalid-feedback">
              Please add some comments
            </div>

          </div>

          <button class="btn btn-dark">
            Submit
          </button>

        </form>

      <% } %>

      <!-- All Reviews -->

      <% if (listing.reviews.length > 0) { %>

        <div class="row mt-4">

          <p>
            <b>All Reviews</b>
          </p>

          <% for (let review of listing.reviews) { %>

            <div class="col-12 col-md-5 mb-3 ms-md-3">

              <div class="card h-100">

                <div class="card-body">

                  <h5 class="card-title">
                    @<%= review.author.username %>
                  </h5>

                  <p class="card-text">
                    <%= review.comment %>
                  </p>

                  <p
                    class="starability-result card-text"
                    data-rating="<%= review.rating %>"
                  >
                    Rated:
                    <%= review.rating %> stars
                  </p>

                  <form
                    method="POST"
                    action="/listing/<%= listing._id %>/review/<%= review._id %>?_method=DELETE"
                  >
                    <button class="btn btn-sm btn-dark">
                      Delete
                    </button>
                  </form>

                </div>

              </div>

            </div>

          <% } %>

        </div>

      <% } %>

    </div>
  </div>

  <!-- Map -->

  <div class="row">
    <div class="col-12 col-md-8 offset-md-2 mb-4">

      <h3>Where you'll be</h3>

      <div id="map"></div>

    </div>
  </div>

</div>

<script>
  const listing = <%- JSON.stringify(listing) %>;
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const toPicker = flatpickr("#toDate", {
    minDate: "today",
    dateFormat: "Y-m-d"
  });

  flatpickr("#fromDate", {
    minDate: "today",
    dateFormat: "Y-m-d",
    onChange: function(selectedDates, dateStr) {
      toPicker.set("minDate", dateStr);
    }
  });

});
</script>

<script src="/js/map.js"></script>